  OPENED
  FINISHED
  AGING_INTENTIONALLY
}

enum PlaceType {
  BAR
  RESTAURANT
  BREWERY
  SHOP
  TASTING_ROOM
  OTHER
}

enum EventType {
  SAKE_TASTING
  SAKE_EDUCATION
  PAIRING_DINNER
  BREWER_VISIT
  FESTIVAL
  BAR_TAKEOVER
  OTHER
}

enum AlertType {
  CELLAR_DRINKING_WINDOW
  CELLAR_EXPIRING
  EVENT_TOMORROW
  EVENT_THIS_WEEK
  COMMUNITY_REPLY
  RECOMMENDATION_SAKE
  RECOMMENDATION_ARTICLE
  OTHER
}

enum AlertEntityType {
  CELLAR_ENTRY
  EVENT
  COUNTER_POST
  COUNTER_REPLY
  LEARN_ARTICLE
  SAKE_BOTTLE
  NONE
}

enum CounterPostType {
  SAKE_SHARE   // "Share a sake"
  ASK          // "Ask the group"
  TRIP         // "Ask about Japan" / trip planning
}

enum EventReservationStatus {
  CONFIRMED
  CANCELED
  WAITLISTED
}

// ============================================
// [KINFOLK] USER PROFILE & ONBOARDING
// ============================================

/// Display-facing user profile (distinct from UserTasteProfile which holds taste math).
/// One row per Supabase auth user. Holds display name, avatar, join date, public-profile config.
model UserProfile {
  id     String @id @default(cuid())
  userId String @unique

  displayName String?
  avatarUrl   String?
  bio         String? @db.Text

  // Optional public-profile settings (Profile → Share)
  isProfilePublic   Boolean @default(false)
  publicProfileSlug String? @unique

  // Cached signature quote shown at top of Profile page
  signatureQuote            String?   @db.Text
  signatureQuoteGeneratedAt DateTime?

  // Tracking
  joinedAt  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_profiles")
}

/// Onboarding progress flags — drives the Account_Setup flow and
/// conditional nudges (e.g., "Finish your palate quiz").
model UserOnboardingState {
  id     String @id @default(cuid())
  userId String @unique

  hasCompletedQuiz         Boolean @default(false)
  hasSetDisplayName        Boolean @default(false)
  hasScannedFirstLabel     Boolean @default(false)
  hasLoggedFirstDiaryEntry Boolean @default(false)
  hasAddedCellarBottle     Boolean @default(false)

  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_onboarding_states")
}

// ============================================
// [KINFOLK] CELLAR (INVENTORY)
// Drives: sakeyo_Cellar.html, Cellar_Add.html, Cellar_Detail.html
// ============================================

/// One row per bottle the user owns. Unlike UserBottleRating (taste signal)
/// or UserSakeDiaryEntry (tasting event), this tracks physical inventory state.
model CellarEntry {
  id           String @id @default(cuid())
  userId       String
  sakeBottleId String

  // Purchase info
  purchaseDate  DateTime?
  source        String?  // "Shop, bar, trip — wherever"
  price         Float?
  priceCurrency String?
  volumeMl      Int?     // 180, 300, 500, 720, 1800, or custom

  // Status tracking
  status     CellarEntryStatus @default(UNOPENED)
  openedAt   DateTime? // Set when user marks as opened (or via Cellar_Add "Opened today")
  finishedAt DateTime? // Set when user marks as finished

  // Storage
  storageType StorageType?
  location    String?  // Free-form label, e.g. "Wine fridge · A-3"

  // User notes
  notes String? @db.Text

  // Alerts
  drinkByAlertsEnabled Boolean @default(false)

  // Derived / cached drink-by date (computed from bottle style + openedAt).
  // Populated by background job or on-write; nullable when not yet computed.
  drinkByDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sakeBottle SakeBottle @relation(fields: [sakeBottleId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([sakeBottleId])
  @@index([userId, drinkByDate])
  @@map("cellar_entries")
}

// ============================================
// [KINFOLK] DIARY EXTENSIONS
// Drives: Diary_Add.html "Paired with" multi-row builder
// ============================================

/// A single "Paired with" entry attached to a UserSakeDiaryEntry.
/// Multiple rows per diary entry, ordered by orderIndex.
model DiaryPairing {
  id           String @id @default(cuid())
  diaryEntryId String

  dishName     String
  reactionNote String? @db.Text // e.g. "lifted the dashi"
  orderIndex   Int     @default(0)

  createdAt DateTime @default(now())

  diaryEntry UserSakeDiaryEntry @relation(fields: [diaryEntryId], references: [id], onDelete: Cascade)

  @@index([diaryEntryId])
  @@map("diary_pairings")
}

// ============================================
// [KINFOLK] PLACES, WISHLIST & PASSPORT
// Drives: Wishlist.html, Passport.html, Home "Top breweries" feed
// ============================================

/// Bars, restaurants, tasting rooms, shops, brewery tasting rooms, etc.
/// Distinct from SakeBrewery (which is the production entity). A brewery's
/// tasting room that is visitable is both: a SakeBrewery record AND a Place
/// record (linked via name/address, not a hard FK — intentional to keep
/// the catalogs editorially independent).
model Place {
  id String @id @default(cuid())

  name        String
  type        PlaceType
  prefecture  String?
  city        String?
  address     String?
  website     String?
  phone       String?
  description String? @db.Text
  imageUrl    String?

  // Editorial source attribution (e.g., Wishlist "source quote")
  sourceQuote          String? @db.Text
  sourceLearnArticleId String?

  // Coordinates
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sourceLearnArticle LearnArticle?    @relation(fields: [sourceLearnArticleId], references: [id])
  savedByUsers       UserSavedPlace[]
  passportEntries    PassportEntry[]

  @@index([type])
  @@index([prefecture])
  @@map("places")
}

/// User's saved/wishlisted places. "Wishlist" tab on Wishlist.html.
model UserSavedPlace {
  id      String   @id @default(cuid())
  userId  String
  placeId String
  savedAt DateTime @default(now())

  place Place @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@unique([userId, placeId])
  @@index([userId])
  @@map("user_saved_places")
}

/// A Passport entry: a logged visit to a Place, with optional bottles tasted
/// and photos. Drives sakeyo_Passport.html.
model PassportEntry {
  id      String @id @default(cuid())
  userId  String
  placeId String

  visitDate     DateTime
  durationHours Float?
  notes         String? @db.Text

  // Attribution — "From article" link shown on passport card
  sourceLearnArticleId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  place              Place                 @relation(fields: [placeId], references: [id])
  sourceLearnArticle LearnArticle?         @relation(fields: [sourceLearnArticleId], references: [id])
  drankBottles       PassportEntryBottle[]
  photos             PassportPhoto[]

  @@index([userId, visitDate])
  @@index([placeId])
  @@map("passport_entries")
}

/// "What we drank" row on a Passport entry. Optional bottleId for catalog match,
/// fallback to free-text bottleName for unrecognized bottles.
model PassportEntryBottle {
  id              String  @id @default(cuid())
  passportEntryId String
  sakeBottleId    String?
  bottleName      String? // Free text when sakeBottleId is null
  rating          Int?    // 1-5
  notes           String?

  createdAt DateTime @default(now())

  passportEntry PassportEntry @relation(fields: [passportEntryId], references: [id], onDelete: Cascade)
  sakeBottle    SakeBottle?   @relation(fields: [sakeBottleId], references: [id])

  @@index([passportEntryId])
  @@map("passport_entry_bottles")
}

/// Photos attached to a Passport entry.
model PassportPhoto {
  id              String @id @default(cuid())
  passportEntryId String
  imageUrl        String
  caption         String?
  orderIndex      Int    @default(0)
  createdAt       DateTime @default(now())

  passportEntry PassportEntry @relation(fields: [passportEntryId], references: [id], onDelete: Cascade)

  @@index([passportEntryId])
  @@map("passport_photos")
}

// ============================================
// [KINFOLK] CALENDAR & EVENTS
// Drives: Calendar.html, Calendar_Agenda.html, Event_Detail.html
// ============================================

model Event {
  id   String  @id @default(cuid())
  slug String? @unique

  name        String
  type        EventType
  lede        String? // Short subhead
  description String? @db.Text
  imageUrl    String?

  // Logistics
  startAt         DateTime
  endAt           DateTime?
  durationMinutes Int?
  timezone        String?

  // Location (placeId when cataloged; venueName/address as fallback / override)
  placeId      String?
  venueName    String?
  venueAddress String?
  prefecture   String?

  // Pricing & seats
  price         Float?
  priceCurrency String?
  maxSeats      Int?
  reservedSeats Int    @default(0)

  // Host (denormalized for simplicity; can be normalized to Host table later)
  hostUserId    String?
  hostName      String?
  hostRole      String?
  hostBio       String? @db.Text
  hostAvatarUrl String?

  // Marketplace tie-in copy shown on Event_Detail
  marketplaceTieInText String? @db.Text

  // Editorial flags
  isFeatured  Boolean   @default(false)
  published   Boolean   @default(false)
  publishedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  place        Place?             @relation(fields: [placeId], references: [id])
  savedByUsers UserSavedEvent[]
  reservations EventReservation[]

  @@index([type])
  @@index([startAt])
  @@index([prefecture])
  @@map("events")
}

model UserSavedEvent {
  id      String   @id @default(cuid())
  userId  String
  eventId String
  savedAt DateTime @default(now())

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([userId])
  @@map("user_saved_events")
}

/// User RSVP/reservation. Event_Detail "Reserve" button writes here.
model EventReservation {
  id      String @id @default(cuid())
  userId  String
  eventId String

  seats  Int                    @default(1)
  status EventReservationStatus @default(CONFIRMED)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([userId, eventId])
  @@index([eventId])
  @@map("event_reservations")
}

// ============================================
// [KINFOLK] ALERTS / NOTIFICATIONS
// Drives: Alerts.html (inbox), plus push-notification triggers
// ============================================

/// User-facing notification row. Polymorphic via (entityType, entityId) —
/// deep-link path optional for client-side routing.
model Alert {
  id     String @id @default(cuid())
  userId String

  type       AlertType
  entityType AlertEntityType @default(NONE)
  entityId   String?

  title       String
  description String? @db.Text

  isRead Boolean   @default(false)
  readAt DateTime?

  // Optional deep-link path resolved by the app router
  deepLinkPath String?

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("alerts")
}

// ============================================
// [KINFOLK] COUNTER (COMMUNITY)
// Drives: Counter.html feed, Counter_Note.html detail+replies
// ============================================

/// A community post. Three post types share this table for a unified feed;
/// type-specific fields are nullable.
model CounterPost {
  id     String @id @default(cuid())
  userId String

  type CounterPostType

  headline String?     // Optional title (e.g., shared sake note headline)
  body     String      @db.Text

  // SAKE_SHARE — link to bottle being shared
  sakeBottleId String?

  // TRIP — city/prefecture context
  tripCity       String?
  tripPrefecture String?

  // ASK — optional context image
  askContextImageUrl String?

  // Moderation / curation
  isPinned Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sakeBottle SakeBottle?            @relation(fields: [sakeBottleId], references: [id])
  replies    CounterReply[]
  savedBy    UserSavedCounterPost[]

  @@index([type, createdAt])
  @@index([userId])
  @@map("counter_posts")
}

model CounterReply {
  id            String @id @default(cuid())
  counterPostId String
  userId        String

  body       String  @db.Text
  isEndorsed Boolean @default(false) // Pinned/expert answer indicator

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  counterPost CounterPost @relation(fields: [counterPostId], references: [id], onDelete: Cascade)

  @@index([counterPostId, createdAt])
  @@map("counter_replies")
}

model UserSavedCounterPost {
  id            String   @id @default(cuid())
  userId        String
  counterPostId String
  savedAt       DateTime @default(now())

  counterPost CounterPost @relation(fields: [counterPostId], references: [id], onDelete: Cascade)

  @@unique([userId, counterPostId])
  @@index([userId])
  @@map("user_saved_counter_posts")
}

// ============================================
// [KINFOLK] BOOKMARKS — LEARN ARTICLES
// Drives: Pairings.html (bookmark button on editorial pairing guides)
// ============================================

model UserSavedLearnArticle {
  id             String   @id @default(cuid())
  userId         String
  learnArticleId String
  savedAt        DateTime @default(now())

  learnArticle LearnArticle @relation(fields: [learnArticleId], references: [id], onDelete: Cascade)

  @@unique([userId, learnArticleId])
  @@index([userId])
  @@map("user_saved_learn_articles")
}
